<section id="pricing">
    <div class="container py-5">
        <div class="row text-center mb-5">
            <div class="col">
                <h4 class="display-6 " style="color: #F677AA;">Choose Your Support Plan</h4>
                <p class="text-muted">Pick the pack that fits your business size and let Birdlet handle the rest.</p>
            </div>
        </div>
        <div class="row row-cols-1 row-cols-md-4 g-4">
            <!-- Basic Plan -->
            <div class="col">
                <div class="card h-100 pricing-card shadow-sm">
                    <div class="card-body p-5">
                        <h5 class="card-title text-muted text-uppercase mb-4">Ultra Lite</h5>
                        <p class="text-muted">Perfect for new or small businesses</p>
                        <h1 class="display-5 mb-4">$50<small class="text-muted fw-light">/mo</small></h1>
                        <ul class="list-unstyled feature-list">
                            <li><i class="bi bi-check2 text-primary "></i>Email support. Up to 50 emails/month</li>
                            <li><i class="bi bi-check2 text-primary "></i>Monthly performance summary</li>
                            <li><i class="bi bi-check2 text-primary "></i>Stress-free onboarding</li>
                        </ul>
                        @* <button class="btn btn-outline-primary btn-lg w-100 mt-4">Get Started</button> *@
                    </div>
                </div>
            </div>

            <!-- Pro Plan -->
            <div class="col">
                <div class="card h-100 pricing-card shadow-sm">
                    <div class="card-body p-5">
                        <h5 class="card-title text-muted text-uppercase mb-4">Feather Pack</h5>
                        <p class="text-muted">For growing brands that need more structure</p>
                        <h1 class="display-5 mb-4">$250<small class="text-muted fw-light">/mo</small></h1>
                        <ul class="list-unstyled feature-list">
                            <li><i class="bi bi-check2 text-primary "></i>Email support. 50 to 150 emails/month</li>
                            <li><i class="bi bi-check2 text-primary "></i>Chat support</li>
                            <li><i class="bi bi-check2 text-primary "></i>24h guaranteed response time</li>
                            <li><i class="bi bi-check2 text-primary "></i>Monthly detailed report</li>
                        </ul>
                        @*  <button class="btn gradient-custom text-white btn-lg w-100 mt-4">Get Started</button> *@
                    </div>
                </div>
            </div>

            <!-- Enterprise Plan -->
            <div class="col">
                <div class="card h-100 pricing-card shadow position-relative">
                    <span class="badge gradient-custom text-white popular-badge px-4 py-2">Popular</span>
                    <div class="card-body p-5">
                        <h5 class="card-title text-primary text-uppercase mb-4">Wing Pack</h5>
                        <p class="text-muted">More coverage for busy e-commerce shops</p>
                        <h1 class="display-5 mb-4">$350<small class="text-muted fw-light">/mo</small></h1>
                        <ul class="list-unstyled feature-list">
                            <li><i class="bi bi-check2 text-primary "></i>Email support. 150 to 300 emails/month</li>
                            <li><i class="bi bi-check2 text-primary "></i>Chat support</li>
                            <li><i class="bi bi-check2 text-primary "></i>Social media DMs (Instagram/Facebook)</li>
                            <li><i class="bi bi-check2 text-primary "></i>Full monthly report + insights</li>
                        </ul>
                        @*   <button class="btn btn-outline-primary btn-lg w-100 mt-4">Get Started</button> *@
                    </div>
                </div>
            </div>

            <!-- ULTRA Enterprise Plan -->
            <div class="col">
                <div class="card h-100 pricing-card shadow-sm">
                    <div class="card-body p-5">
                        <h5 class="card-title text-muted text-uppercase mb-4">Flight Pack</h5>
                        <p class="text-muted">High-volume, full-service support</p>
                        <h1 class="display-5 mb-4">$600<small class="text-muted fw-light">/mo</small></h1>
                        <ul class="list-unstyled feature-list">
                            <li><i class="bi bi-check2 text-primary "></i>Email support. 300 to 500 emails/month</li>
                            <li><i class="bi bi-check2 text-primary "></i>Chat support</li>
                            <li><i class="bi bi-check2 text-primary "></i>Social media messaging (multi-platform)</li>
                            <li><i class="bi bi-check2 text-primary "></i>Priority reporting & performance insights</li>
                            <li><i class="bi bi-check2 text-primary "></i>Dedicated support coordinator</li>
                        </ul>
                        @*   <button class="btn btn-outline-primary btn-lg w-100 mt-4">Get Started</button> *@
                    </div>
                </div>
            </div>

        </div>

        @* 1. Didn’t find what you’re looking for? *@
        <div class=" m-5 card p-4">

            <div class="d-flex align-items-baseline mb-3">
                <div class="icon-circle text-white me-3" style="background-color: #F14C93;">
                    <i class="fa fa-question fa-sm"></i>
                </div>
                <div>
                    <h4 class="text-muted">Didn’t find what you’re looking for?</h4>
                </div>
            </div>

            <h5 class="text-muted">We know every business is unique and so is your support need. Send us an email or book a quick call we’ll build a custom solution just for you.</h5>
            <h5 class="m-3" style="color: #F14C93;">Let Birdlet shape the sperfect support wings for your brand.</h5>
        </div>
    </div>
</section>


